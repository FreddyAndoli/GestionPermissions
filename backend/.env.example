# Serveur
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000

# Base de donnees MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=pm_user
DB_PASSWORD=password
DB_NAME=permission_manager
DATABASE_URL=mysql://pm_user:password@localhost:3306/permission_manager

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PERMISSIONS_TTL=900
REDIS_SESSION_TTL=3600
REDIS_RATE_LIMIT_WINDOW=60
REDIS_RATE_LIMIT_MAX=100
REDIS_LOGIN_ATTEMPTS_MAX=5
REDIS_LOCKOUT_DURATION=900

# Dev auth bypass secret (required when using dev mode; never share or commit the real value)
DEV_SECRET=your-random-secret-here-never-share

# Firebase Admin SDK (optional in development — dev auth bypass is available)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Notifications
NOTIFICATION_PROVIDER=telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
FCM_SERVER_KEY=

# PDF
PDF_STORAGE_PATH=./storage/reports

# Logs
LOG_LEVEL=info
LOG_DIR=./logs
